# Copy to .env (or .env.local) and fill in.
# Get these from Firebase Console → Project Settings → Your apps → SDK setup.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=knowsy-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=knowsy-xxxxx
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_STORAGE_BUCKET=knowsy-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000

# Controls per-widget visibility:
#   development → show every widget regardless of STATUS (for local dev + staging)
#   production  → show only widgets whose source declares `export const STATUS = 'done'`
# Leave as 'development' for `npm run dev`. The deploy workflows override it.
VITE_ENVIRONMENT=development

# Optional: Sentry DSN for error tracking. Leave blank to disable.
VITE_SENTRY_DSN=

# Notes:
# - Google sign-in works once you enable Google in Firebase Console → Authentication → Sign-in method.
# - Apple sign-in requires an Apple Developer account ($99/yr) + Service ID + key in Apple Developer,
#   then enable Apple in Firebase Console with those credentials.
# - Rutgers SSO is wired as a SAML provider with ID "saml.rutgers". This requires the
#   Firebase Identity Platform tier (paid GCP) AND a SAML registration with Rutgers OIT
#   pointing at https://shib.rutgers.edu/idp/shibboleth. Until that's set up, the
#   Rutgers button will show a friendly error and not crash the page.
