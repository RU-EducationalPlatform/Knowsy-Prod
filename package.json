{
  "name": "knowsy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Knowsy — an interactive textbook for the curious.",
  "scripts": {
    "dev": "vite",
    "dev:emu": "bash infra/scripts/dev.sh",
    "dev:emu:reseed": "bash infra/scripts/dev.sh --reseed",
    "dev:emu:clean": "bash infra/scripts/dev.sh --clean",
    "dev:web": "VITE_USE_EMULATORS=1 vite",
    "seed": "node infra/functions/seed-test-users.mjs",
    "deploy": "npm run build && firebase deploy --only hosting",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "ci": "npm run lint && npm run test && npm run build",
    "check": "node tools/check.mjs"
  },
  "dependencies": {
    "@sentry/browser": "^8.30.0",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^10.13.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "web-vitals": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.10.0",
    "firebase-tools": "^15.17.0",
    "globals": "^15.9.0",
    "happy-dom": "^15.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
